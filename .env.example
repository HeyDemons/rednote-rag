APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
SQL_ECHO=false

DATABASE_URL=sqlite+aiosqlite:///./data/rednote_rag.db
CHROMA_PERSIST_DIRECTORY=./data/chroma_db

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small
ALLOW_LOCAL_EMBED_FALLBACK=false
OCR_ENABLED=false
OCR_MODEL=
OCR_MAX_IMAGES_PER_NOTE=6
OCR_TIMEOUT_SECONDS=30

XHS_COOKIE_SOURCE=auto
XHS_REQUEST_DELAY=1.0
